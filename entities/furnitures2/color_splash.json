                "hp4_paint:furniture_model": {
                    "client_sync": true,
                    "default": "math.floor(math.random(0, 4))",
                    "type": "int",
                    "range": [
                        0,
                        4
                    ]
                },
                "hp4_paint:furniture_color": {
                    "client_sync": true,
                    "default": "math.floor(math.random(0, 15))",
                    "type": "int",
                    "range": [
                        0,
                        15
                    ]
                },
                "hp4_paint:stencil_vertical_rotation": {
                    "client_sync": true,
                    "default": 0,
                    "type": "int",
                    "range": [-90, 90]
                },
                "hp4_paint:stencil_y_rotation": {
                    "client_sync": true,
                    "default": 0,
                    "type": "int",
                    "range": [-180, 180]
                },
                "hp4_paint:outline": {
                    "client_sync": true,
                    "default": false,
                    "type": "bool"
                }
            }
        },
        "components": {
