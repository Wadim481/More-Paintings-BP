{
    "format_version": "1.16.0",
    "minecraft:entity": {
        "description": {
            "identifier": "hp4_paint:stencil_shovel",
            "is_spawnable": false,
            "is_summonable": true,
            "is_experimental": false,
            "properties": {
                "hp4_paint:furniture_model": {
                    "client_sync": true,
                    "default": 5,
                    "type": "int",
                    "range": [
                        -99999,
                        99999
                    ]
                },
                "hp4_paint:stencil_vertical_rotation": {
                    "client_sync": true,
                    "default": 0,
                    "type": "int",
                    "range": [-90, 90]
                },
                "hp4_paint:stencil_y_rotation": {
                    "client_sync": true,
                    "default": 0,
                    "type": "int",
                    "range": [-180, 180]
                },
                "hp4_paint:outline": {
                    "client_sync": true,
                    "default": false,
                    "type": "bool"
                }
            }
        },
        "components": {
            "minecraft:type_family": {
                "family": [ "hp4_paint_furniture" ]
            },
            "minecraft:interact": {
                "interactions": [
                    {
                        "on_interact": {
                            "filters": {
                                "all_of": [
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "player"
                                    }
                                ]
                            }
                        },
                        "interact_text": "Change model",
                        "hurt_item": 1
                    }
                ]
            },
            "minecraft:knockback_resistance": {
                "value": 1000
            },
            "minecraft:collision_box": {
                "height": -0.1,
                "width": -0.1
            },
            "minecraft:health": {
                "value": 1,
                "max": 1
            },
            "minecraft:pushable": {
                "is_pushable": false,
                "is_pushable_by_piston": false
            },
            "minecraft:damage_sensor": {
                "triggers": [
                    {
                        "on_damage": {
                            "event": "death"
                        },
                        "cause": "entity_attack",
                        "deals_damage": false
                    },
                    {
                        "cause": "suffocation",
                        "deals_damage": false
                    }
                ]
            }
        },
        "component_groups": {
            "hp4_paint:stencil_hitbox_floor": {
                "minecraft:custom_hit_test": {
                    "hitboxes": [
                        {
                            "width": 0.8,
                            "height": 0.8,
                            "pivot": [
                                0,
                                0,
                                0
                            ]
                        }
                    ]
                }
            },
            "hp4_paint:stencil_hitbox_wall": {
                "minecraft:custom_hit_test": {
                    "hitboxes": [
                        {
                            "width": 0.8,
                            "height": 0.8,
                            "pivot": [
                                0,
                                0.5,
                                0
                            ]
                        }
                    ]
                }
            },
            "death": {
                "minecraft:instant_despawn": {}
            }
        },
        "events": {
            "minecraft:entity_spawned": {
                "add": {
                    "component_groups": [
                        "hp4_paint:stencil_hitbox_floor"
                    ]
                },
                "remove": {
                    "component_groups": [
                        "hp4_paint:stencil_hitbox_wall"
                    ]
                }
            },
            "hp4_paint:stencil_hitbox_floor": {
                "add": {
                    "component_groups": [
                        "hp4_paint:stencil_hitbox_floor"
                    ]
                },
                "remove": {
                    "component_groups": [
                        "hp4_paint:stencil_hitbox_wall"
                    ]
                }
            },
            "hp4_paint:stencil_hitbox_wall": {
                "add": {
                    "component_groups": [
                        "hp4_paint:stencil_hitbox_wall"
                    ]
                },
                "remove": {
                    "component_groups": [
                        "hp4_paint:stencil_hitbox_floor"
                    ]
                }
            },
            "death": {
                "sequence": [
                    
                    {
                        "queue_command": {
                           "command": ["particle hp4_paint:d_stencils ~ ~0.4 ~"]
                        }
                    },
                    {
                        "queue_command": {
                            "command": "playsound dig.wood @a[r=10]"
                        }
                    }
                ]
            }
        }
    }
}